{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MySekaiStoryteller",
  "version": "1.0.0",
  "identifier": "org.untitled-story.storyteller",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MySekaiStoryteller",
        "url": "/src/windows/main/index.html",
        "width": 1000,
        "height": 600,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
