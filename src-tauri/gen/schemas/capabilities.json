{
  "default": {
    "identifier": "default",
    "description": "Capability for all windows",
    "local": true,
    "windows": ["main", "editor", "player"],
    "permissions": [
      "core:default",
      "core:window:allow-close",
      "core:window:allow-set-focus",
      "core:event:default",
      "dialog:default",
      "global-shortcut:allow-is-registered",
      "global-shortcut:allow-register",
      "global-shortcut:allow-unregister",
      "global-shortcut:allow-unregister-all",
      "log:default",
      "opener:default"
    ]
  },
  "editor": {
    "identifier": "editor",
    "description": "Additional permissions for the editor window",
    "local": true,
    "windows": ["editor"],
    "permissions": ["core:window:allow-destroy"]
  },
  "player": {
    "identifier": "player",
    "description": "Additional permissions for the borderless player window",
    "local": true,
    "windows": ["player"],
    "permissions": ["core:window:allow-start-dragging", "core:window:allow-set-fullscreen"]
  }
}
