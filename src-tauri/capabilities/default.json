{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for all windows",
  "windows": ["main", "editor", "player"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:event:default",
    "dialog:default",
    "log:default",
    "opener:default"
  ]
}
